{
    auto_https off
}

:80 {
    encode zstd gzip

    @health path /healthz
    respond @health "ok" 200

    # Django authorises; Caddy intercepts X-Accel-Redirect and range-serves bytes
    # from /srv/nakavid without passing video through Django view code.
    reverse_proxy host.docker.internal:8000 {
        @accel header X-Accel-Redirect *
        handle_response @accel {
            root * /srv/nakavid
            rewrite * {rp.header.X-Accel-Redirect}
            method GET
            file_server
        }
    }
}
